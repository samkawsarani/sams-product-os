# Linear API Key (personal key from Linear settings)
LINEAR_API_KEY=lin_api_xxx

# Slack User Token (xoxp- prefix, from Slack app OAuth)
SLACK_USER_TOKEN=xoxp-xxx

# HubSpot - Private App access token
HUBSPOT_CLIENT_ID=XXXXXXXX-XXXX-XXXX-XXXX-XXXXXXXXXXXX
HUBSPOT_CLIENT_SECRET=abcdefghijklmnopqrstuvwxyz0123456789

# Anthropic API key for evals
ANTHROPIC_API_KEY=XXXXX